# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Initial admin user. If AUTH_CHALLENGE is true, you need at least one user.
AUTH_USER=admin
AUTH_PASS=change_me_strong_password
ADMIN_USER=admin

# Optional: additional users as JSON. Keys = usernames, values = plaintext passwords.
# AUTH_USERS='{"user1":"pass1","user2":"pass2"}'

# Optional but recommended: a secret used to sign sessions and salt analytics IPs.
# If unset, a random value is generated per restart (sessions won't survive restarts).
AUTH_SECRET=change_me_random_64_char_hex

# -----------------------------------------------------------------------------
# App settings
# -----------------------------------------------------------------------------
# Server port (inside the container). Caddy proxies to this.
PORT=8080
HOST=0.0.0.0

# Tell Fastify to trust the X-Forwarded-* headers from Caddy.
TRUST_PROXY=true

# Optional: set to true on first build if you want the legacy first-run behavior.
FIRST=false

# Enable/disable route name obfuscation and response compression.
OBFUSCATE=true
COMPRESS=true

# Enable/disable the auth login challenge. Set to false to make the proxy public.
AUTH_CHALLENGE=true

# Optional: token required for POST /api/sync-games. Generate with:
#   openssl rand -hex 32
SYNC_TOKEN=

# Optional: stable salt for hashing analytics IPs.
ANALYTICS_IP_SALT=

# -----------------------------------------------------------------------------
# Caddy settings
# -----------------------------------------------------------------------------
# Your domain (must point to the VPS IP before running docker compose up).
CADDY_DOMAIN=your-domain.com

# Email for Let's Encrypt reminders.
CADDY_EMAIL=you@example.com
