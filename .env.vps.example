# ARM$N VPS environment template
# Copy this file to .env and edit as needed before starting the app.

# Server
PORT=8080
HOST=0.0.0.0
OBFUSCATE=true
COMPRESS=true

# Trust X-Forwarded-* headers from the Caddy reverse proxy.
# This is required when running behind the included Caddy container.
TRUST_PROXY=true

# Caddy reverse proxy (optional - used when you add a domain later)
# Leave empty to serve over plain HTTP on the VPS IP address.
CADDY_DOMAIN=
CADDY_EMAIL=

# Auth (enabled by default)
# Without Supabase, users are defined by AUTH_USER/AUTH_PASS and AUTH_USERS only.
AUTH_CHALLENGE=true
AUTH_USER=admin
AUTH_PASS=change-me-strong-password
AUTH_SECRET=change-me-to-a-long-random-string

# Supabase (optional - only needed for multi-user admin panel and analytics)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Analytics (optional)
ANALYTICS_IP_SALT=change-me

# Game sync token (optional)
SYNC_TOKEN=change-me
