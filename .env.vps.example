PORT=8080
HOST=0.0.0.0

# App behavior
OBFUSCATE=true
COMPRESS=true
TRUST_PROXY=true

# Auth (required)
AUTH_CHALLENGE=true
AUTH_USER=admin
AUTH_PASS=change-me-strong-password
AUTH_SECRET=change-me-random-secret

# Comma-separated list of additional usernames that should be treated as admins.
# The user set in AUTH_USER is always an admin.
AUTH_ADMINS=

# Caddy / domain (optional, set after pointing a domain at the server)
CADDY_DOMAIN=
CADDY_EMAIL=

# Supabase (optional, enables analytics and dynamic user management)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Other secrets
ANALYTICS_IP_SALT=change-me
SYNC_TOKEN=change-me
