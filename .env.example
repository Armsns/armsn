[TEMPLATE]
# Server
PORT=8080
# Use 0.0.0.0 to accept remote connections; 127.0.0.1 for local-only
HOST=127.0.0.1
OBFUSCATE=true
COMPRESS=true

# Supabase (required when AUTH_CHALLENGE=true)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Auth
# Set AUTH_CHALLENGE=false to disable login entirely.
# When enabled, set AUTH_USER and AUTH_PASS to create the first admin user.
AUTH_CHALLENGE=true
AUTH_USER=admin
AUTH_PASS=change-me

# Optional: secret used to sign session cookies (random if not set)
AUTH_SECRET=change-me

# Analytics (optional)
# Stable salt used to hash visitor IPs. If not set, falls back to AUTH_SECRET or SUPABASE_SERVICE_KEY.
ANALYTICS_IP_SALT=change-me

# Proxy trust (optional)
# Set to true when running behind a trusted reverse proxy so req.ip uses X-Forwarded-For.
# Do NOT enable this if the server is exposed directly to the internet.
TRUST_PROXY=false

# Dev proxy (optional)
# When running `npm run dev`, /api requests are proxied to this URL.
# Defaults to http://localhost:8080. Only used in development.
API_PROXY_URL=http://localhost:8080
