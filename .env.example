# Server
PORT=8080
OBFUSCATE=true
COMPRESS=true

# Supabase (required when AUTH_CHALLENGE=true)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
# Set AUTH_CHALLENGE=false to disable login entirely.
# When enabled, set AUTH_USER and AUTH_PASS to create the first admin user.
AUTH_CHALLENGE=true
AUTH_USER=admin
AUTH_PASS=change-me

# Optional: secret used to sign session cookies (random if not set)
AUTH_SECRET=change-me
